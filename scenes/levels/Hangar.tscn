; --- WaveSystem ---
; El Hangar ES el modo "endless": tras la wave 3 se generan waves dinámicas
; con scaling progresivo. El pool define qué enemy_data se permiten.
[node name="WaveSystem" type="Node" parent="."]
script = ExtResource("5")
waves = Array[Resource]([SubResource("W1"), SubResource("W2"), SubResource("W3")])
spawn_points_path = NodePath("../SpawnPoints")
initial_delay = 4.0
time_between_waves = 4.0
endless_mode = true
endless_pool = Array[Resource]([ExtResource("EG"), ExtResource("ES"), ExtResource("EH"), ExtResource("EA"), ExtResource("EB"), ExtResource("EAL")])

