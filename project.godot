; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="worldFarm"
run/main_scene="res://scenes/ui/MainMenu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://scripts/autoload/EventBus.gd"
GameState="*res://scripts/autoload/GameState.gd"
RNG="*res://scripts/autoload/RNG.gd"
Settings="*res://scripts/autoload/Settings.gd"
InputSetup="*res://scripts/autoload/InputSetup.gd"
AudioManager="*res://scripts/autoload/AudioManager.gd"
DamageNumbers="*res://scripts/systems/vfx/DamageNumbers.gd"
NoaDialog="*res://scripts/systems/ui/NoaDialog.gd"
HackingSystem="*res://scripts/systems/ui/HackingSystem.gd"
Achievements="*res://scripts/systems/Achievements.gd"
Codex="*res://scripts/systems/Codex.gd"

[filesystem]

import/blender/enabled=false

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
